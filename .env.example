# myMEDLIFE local development only.
# Do not commit real secrets in `.env.local`.

# Default behavior is mock data. Set this to `supabase` only when you are
# running the local Supabase stack.
MYMEDLIFE_DATA_SOURCE=mock

# Extra safety switch. Goal 8+ only allows localhost/127.0.0.1 Supabase reads.
MYMEDLIFE_ALLOW_LOCAL_SUPABASE_READS=false

# Documentation-only write switch. Goal 12 keeps writes disabled even if this
# is set to true; a later approved goal must add real write support and tests.
MYMEDLIFE_ALLOW_LOCAL_SUPABASE_WRITES=false

# Documentation-only proof upload switch. Goal 17 keeps proof/video uploads and
# public publishing disabled even if this is set to true.
MYMEDLIFE_ALLOW_PROOF_UPLOADS=false

# Local Supabase Auth switch. Leave disabled unless you are running the local
# Supabase stack and testing fake seed-user sign-in. This refuses non-localhost
# URLs until production auth is explicitly approved.
MYMEDLIFE_AUTH_MODE=disabled

# Local Supabase API URL from `pnpm supabase:start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Local-only key. Use a local key from `pnpm supabase:start`; do not paste a
# production key here. The Goal 8 server read path is GET-only and local-gated.
SUPABASE_SERVICE_ROLE_KEY=

# Optional local-only actor switch for Goal 10+ role-aware read testing.
# This works in mock fallback and against local Supabase fake seed data.
# Fake seed choices include member.a@mymedlife.test, leader.a@mymedlife.test,
# coach@mymedlife.test, admin@mymedlife.test, ds.admin@mymedlife.test, and
# super.admin@mymedlife.test.
MYMEDLIFE_LOCAL_ACTOR_EMAIL=member.a@mymedlife.test

# Future live auth variables. Leave unset for the current local-only goals.
# For local sign-in testing, paste the local anon key from `pnpm supabase:start`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
