# myMEDLIFE local development only.
# Do not commit real secrets in `.env.local`.

# Default behavior is mock data. Set this to `supabase` only when you are
# running the local Supabase stack.
MYMEDLIFE_DATA_SOURCE=mock

# Extra safety switch. Goal 8+ only allows localhost/127.0.0.1 Supabase reads.
MYMEDLIFE_ALLOW_LOCAL_SUPABASE_READS=false

# Documentation-only write switch. Goal 12 keeps writes disabled even if this
# is set to true for most operations. Goal 60 uses this only with the narrower
# action-start flag below, local Supabase Auth, and localhost Supabase.
MYMEDLIFE_ALLOW_LOCAL_SUPABASE_WRITES=false

# Hosted staging write master switch. Keep false unless one approved staging
# write rehearsal is being exercised with fake staging data and hosted staging
# auth already works.
MYMEDLIFE_ALLOW_STAGING_SUPABASE_WRITES=false

# Action start records app-owned assignment status, event, integration-event,
# and audit history without any external send. Production requires the separate
# approval flag below.
MYMEDLIFE_ENABLE_ACTION_START_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_ACTION_START_WRITE=false

# Goal 64 local-only leader assignment-create write switch. Keep false unless
# you are testing the fourth local browser write with fake leader seed users.
# This creates a disabled reminder outbox row but sends no reminders.
MYMEDLIFE_ENABLE_ASSIGNMENT_CREATE_WRITE=false

# Goal 162 membership approval write switch. Keep false unless auth, rollback,
# audit readback, and the first hosted-write rehearsal are explicitly approved.
MYMEDLIFE_ENABLE_MEMBERSHIP_APPROVAL_WRITE=false

# Proof/testimonial metadata writes create an app-owned evidence item, internal
# event, disabled outbox row, and audit record. Production requires the separate
# approval flag below. This does not enable uploads or public proof sharing.
MYMEDLIFE_ENABLE_PROOF_SUBMISSION_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_PROOF_SUBMISSION_WRITE=false

# Goal 63 local-only HQ proof/testimonial decision write switch. Keep false
# unless you are testing the third local browser write with fake HQ seed users.
# This records HQ decision metadata only; it does not publish proof.
MYMEDLIFE_ENABLE_HQ_PROOF_DECISION_WRITE=false

# Goal 65 local-only coach advance/hold/intervene decision write switch. Keep
# false unless you are testing the fifth local browser write with fake coach or
# HQ seed users. This records a disabled escalation outbox row only.
MYMEDLIFE_ENABLE_COACH_DECISION_WRITE=false

# Future private proof upload write switch. Keep false until staging auth,
# storage policies, and DS/security approval all exist.
MYMEDLIFE_ENABLE_PRIVATE_PROOF_UPLOAD_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_PRIVATE_PROOF_UPLOAD_WRITE=false

# Approved story reactions persist in the internal myMEDLIFE event ledger.
# Production requires both switches; shares, saves, and provider writes remain off.
MYMEDLIFE_ENABLE_MEMBER_STORY_REACTION_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_MEMBER_STORY_REACTION_WRITE=false

# Leader proof decisions update app-owned assignment/proof status, approval,
# points/KPI, event, disabled outbox, and audit history. Production requires
# the separate approval flag below. This sends no member nudges, publishes no
# proof, and performs no external write.
MYMEDLIFE_ENABLE_LEADER_PROOF_DECISION_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_LEADER_PROOF_DECISION_WRITE=false

# MED-631 production-safe member event-loop write switch. Keep false unless
# the approved TEST event loop is being exercised with signed-in Supabase Auth,
# server-only service-role access, and live browser readback. This records
# internal RSVP, attendance, and points rows only; it never enables Luma or
# external provider writes. Production also requires the explicit approval flag.
MYMEDLIFE_ENABLE_MEMBER_EVENT_LOOP_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_MEMBER_EVENT_LOOP_WRITE=false

# App-owned leader event creation. This writes only the internal chapter event,
# event ledger, and audit row; external provider writes remain disabled.
# Staging requires both its global hosted-write master switch above and the
# narrower staging event-create approval below.
MYMEDLIFE_ENABLE_LEADER_EVENT_CREATE_WRITE=false
MYMEDLIFE_ALLOW_STAGING_LEADER_EVENT_CREATE_WRITE=false
MYMEDLIFE_ALLOW_PRODUCTION_LEADER_EVENT_CREATE_WRITE=false

# Documentation-only proof upload switch. Goal 17 keeps proof/video uploads and
# public publishing disabled even if this is set to true.
MYMEDLIFE_ALLOW_PROOF_UPLOADS=false

# Server-only HubSpot upstream read sync. Core pages never call HubSpot
# directly; approved companies, contacts, and memberships are reconciled into
# app-owned Supabase rows by hourly incremental and nightly backfill jobs.
# Keep every environment approval false until its credential, active-term
# allowlist, operator, and readback plan are approved.
MYMEDLIFE_ENABLE_HUBSPOT_READ_SYNC=false
MYMEDLIFE_ALLOW_LOCAL_HUBSPOT_READ_SYNC=false
MYMEDLIFE_ALLOW_STAGING_HUBSPOT_READ_SYNC=false
MYMEDLIFE_ALLOW_PRODUCTION_HUBSPOT_READ_SYNC=false
MYMEDLIFE_HUBSPOT_ACTIVE_MEMBER_TERMS=
HUBSPOT_ACCESS_TOKEN=

# Server-only Luma upstream read sync. Approved calendar events are reconciled
# into app-owned Supabase event rows; no Luma event, RSVP, guest, reminder, or
# attendance writes are enabled by these flags. A full backfill also cancels
# app events whose provider record disappears, while bounded reconciliation
# never infers deletion from absence.
MYMEDLIFE_ENABLE_LUMA_READ_SYNC=false
MYMEDLIFE_ALLOW_LOCAL_LUMA_READ_SYNC=false
MYMEDLIFE_ALLOW_STAGING_LUMA_READ_SYNC=false
MYMEDLIFE_ALLOW_PRODUCTION_LUMA_READ_SYNC=false
MYMEDLIFE_LUMA_CHAPTER_ID=
MYMEDLIFE_LUMA_CALENDAR_LABEL=
LUMA_CALENDAR_ID=
LUMA_API_KEY=

# Supabase Auth switch. Leave disabled unless you are running the local
# Supabase stack, the approved staging host, or the approved production host.
# Local mode refuses non-localhost URLs. Staging mode only allows
# staging.mymedlife.org and the approved staging project. Production mode only
# allows www.mymedlife.org and the approved production project, and it refuses
# write/upload flags. Hosted writes still need an explicit staging write switch
# plus the narrower per-write flag.
MYMEDLIFE_AUTH_MODE=disabled

# Local Supabase API URL from `pnpm supabase:start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Local-only key. Use a local key from `pnpm supabase:start`; do not paste a
# production key here. The Goal 8 server read path is GET-only and local-gated.
SUPABASE_SERVICE_ROLE_KEY=

# Admin user lifecycle writes are server-only and disabled by default. Enable
# only after the production migration, RLS review, and disposable-account QA.
MYMEDLIFE_ENABLE_ADMIN_USER_CREATION=false
MYMEDLIFE_ALLOW_PRODUCTION_ADMIN_USER_CREATION=false
MYMEDLIFE_ENABLE_ADMIN_USER_LIFECYCLE=false
MYMEDLIFE_ALLOW_PRODUCTION_ADMIN_USER_LIFECYCLE=false

# Optional local-only actor switch for Goal 10+ role-aware read testing.
# This works in mock fallback and against local Supabase fake seed data.
# Fake seed choices include member.a@mymedlife.test, leader.a@mymedlife.test,
# coach@mymedlife.test, admin@mymedlife.test, ds.admin@mymedlife.test, and
# super.admin@mymedlife.test.
MYMEDLIFE_LOCAL_ACTOR_EMAIL=member.a@mymedlife.test

# Future live auth variables. Leave unset for the current local-only goals.
# For local sign-in testing, paste the local anon key from `pnpm supabase:start`.
# For hosted staging auth, populate these outside source control only.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=

# Optional local PWA service-worker rehearsal. Production builds register the
# service worker automatically; set this to true only when testing the offline
# shell locally.
NEXT_PUBLIC_MYMEDLIFE_ENABLE_SERVICE_WORKER=false

# Sentry observability for myMEDLIFE. The DSN is public; keep SENTRY_AUTH_TOKEN
# only in Vercel/GitHub secrets so release source maps can upload securely.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=medlife-1d
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=local
NEXT_PUBLIC_SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ENABLE_LOGS=false
NEXT_PUBLIC_SENTRY_ENABLE_LOGS=false
NEXT_PUBLIC_SENTRY_REPLAYS_ENABLED=false
