# myMEDLIFE local development only.
# Do not commit real secrets in `.env.local`.

# Default behavior is mock data. Set this to `supabase` only when you are
# running the local Supabase stack.
MYMEDLIFE_DATA_SOURCE=mock

# Extra safety switch. Goal 8+ only allows localhost/127.0.0.1 Supabase reads.
MYMEDLIFE_ALLOW_LOCAL_SUPABASE_READS=false

# Documentation-only write switch. Goal 12 keeps writes disabled even if this
# is set to true for most operations. Goal 60 uses this only with the narrower
# action-start flag below, local Supabase Auth, and localhost Supabase.
MYMEDLIFE_ALLOW_LOCAL_SUPABASE_WRITES=false

# Goal 60 local-only action-start write switch. Keep false unless you are
# testing the first local browser write with fake seed users and local Supabase.
MYMEDLIFE_ENABLE_ACTION_START_WRITE=false

# Goal 64 local-only leader assignment-create write switch. Keep false unless
# you are testing the fourth local browser write with fake leader seed users.
# This creates a disabled reminder outbox row but sends no reminders.
MYMEDLIFE_ENABLE_ASSIGNMENT_CREATE_WRITE=false

# Goal 62 local-only proof/testimonial metadata write switch. Keep false unless
# you are testing the second local browser write with fake seed users and local
# Supabase. This does not enable uploads or public proof sharing.
MYMEDLIFE_ENABLE_PROOF_SUBMISSION_WRITE=false

# Goal 63 local-only HQ proof/testimonial decision write switch. Keep false
# unless you are testing the third local browser write with fake HQ seed users.
# This records HQ decision metadata only; it does not publish proof.
MYMEDLIFE_ENABLE_HQ_PROOF_DECISION_WRITE=false

# Goal 65 local-only coach advance/hold/intervene decision write switch. Keep
# false unless you are testing the fifth local browser write with fake coach or
# HQ seed users. This records a disabled escalation outbox row only.
MYMEDLIFE_ENABLE_COACH_DECISION_WRITE=false

# Goal 116 local-only leader proof decision write switch. Keep false unless
# local Supabase Auth, local RLS tests, and fake proof-review seed data are
# ready. This sends no member nudges and publishes no proof.
MYMEDLIFE_ENABLE_LEADER_PROOF_DECISION_WRITE=false

# Documentation-only proof upload switch. Goal 17 keeps proof/video uploads and
# public publishing disabled even if this is set to true.
MYMEDLIFE_ALLOW_PROOF_UPLOADS=false

# Local Supabase Auth switch. Leave disabled unless you are running the local
# Supabase stack and testing fake seed-user sign-in. This refuses non-localhost
# URLs until production auth is explicitly approved.
MYMEDLIFE_AUTH_MODE=disabled

# Local Supabase API URL from `pnpm supabase:start`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Local-only key. Use a local key from `pnpm supabase:start`; do not paste a
# production key here. The Goal 8 server read path is GET-only and local-gated.
SUPABASE_SERVICE_ROLE_KEY=

# Optional local-only actor switch for Goal 10+ role-aware read testing.
# This works in mock fallback and against local Supabase fake seed data.
# Fake seed choices include member.a@mymedlife.test, leader.a@mymedlife.test,
# coach@mymedlife.test, admin@mymedlife.test, ds.admin@mymedlife.test, and
# super.admin@mymedlife.test.
MYMEDLIFE_LOCAL_ACTOR_EMAIL=member.a@mymedlife.test

# Future live auth variables. Leave unset for the current local-only goals.
# For local sign-in testing, paste the local anon key from `pnpm supabase:start`.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hosted staging review switches. Leave these false or unset until staging review
# auth and the narrow hosted proof path are explicitly approved.
MYMEDLIFE_ENABLE_STAGING_REVIEW_AUTH=false
MYMEDLIFE_ENABLE_STAGING_ACTION_START_WRITE=false
MYMEDLIFE_ENABLE_STAGING_PROOF_SUBMISSION_WRITE=false

# Phase 2 pilot closeout registry. Leave these unset until Nick / Kiomi / DS
# explicitly confirm the final pilot defaults and named owners. Once set, the
# Phase 2 review surfaces (`/admin/phase-2`, `/admin/pilot-scope`,
# `/admin/first-write`, `/admin/release-readiness`, `/admin/launch-gate`, and
# `/onboarding`) will read them as recorded answers instead of recommendations.
MYMEDLIFE_PILOT_CHAPTER=
MYMEDLIFE_PILOT_CAMPAIGN_SCOPE=
MYMEDLIFE_PILOT_COHORT_SIZE=
MYMEDLIFE_PILOT_FIRST_HOSTED_WRITE=
MYMEDLIFE_PILOT_PROOF_REVIEW_LOOP=
MYMEDLIFE_PILOT_EVENT_NPS_POSTURE=
MYMEDLIFE_PILOT_INTEGRATION_HOLD=
MYMEDLIFE_PILOT_CHAPTER_LEADER_OWNER=
MYMEDLIFE_PILOT_COACH_OWNER=
MYMEDLIFE_PILOT_HQ_ADMIN_OWNER=
MYMEDLIFE_PILOT_DS_OWNER=
MYMEDLIFE_PILOT_SUPPORT_PAUSE_CHANNEL=
MYMEDLIFE_PILOT_ROLLBACK_OWNER=

# Optional local PWA service-worker rehearsal. Production builds register the
# service worker automatically; set this to true only when testing the offline
# shell locally.
NEXT_PUBLIC_MYMEDLIFE_ENABLE_SERVICE_WORKER=false
